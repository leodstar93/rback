generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?   // para Credentials
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // RBAC
  roles         UserRole[]
  
  // Documents
  documents     Document[]

  //IFTA
  trucks        Truck[]
  iftaReports   IftaReport[]
  trips         Trip[]
  fuelPurchases FuelPurchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String @id @default(cuid())
  name        String @unique // "ADMIN", "DOCTOR", "STAFF"
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique // "cases:read"
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  description String?
  fileName    String
  fileUrl     String
  fileSize    Int      // in bytes
  fileType    String   // mime type
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

//IFTA SERVICE
enum FuelType {
  DI // Diesel
  GA // Gasoline
}

enum ReportStatus {
  DRAFT
  FILED
  AMENDED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

model Truck {
  id           String   @id @default(cuid())
  unitNumber   String
  plateNumber  String?
  vin          String?  @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trips        Trip[]
  fuelPurchases FuelPurchase[]
  iftaReports  IftaReport[]

  @@index([userId])
}

model Jurisdiction {
  id          String   @id @default(cuid())
  code        String   @unique // NV, CA, AZ
  name        String   @unique // Nevada, California
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taxRates    IftaTaxRate[]
  tripMiles   TripMileage[]
  fuelPurchases FuelPurchase[]
  reportLines IftaReportLine[]
}

model IftaTaxRate {
  id               String       @id @default(cuid())
  jurisdictionId   String
  jurisdiction     Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  year             Int
  quarter          Quarter
  fuelType         FuelType
  taxRate          Decimal      @db.Decimal(10, 4) // ej 1.0230

  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([jurisdictionId, year, quarter, fuelType])
  @@index([year, quarter])
}

model IftaReport {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId           String?
  truck             Truck?        @relation(fields: [truckId], references: [id], onDelete: SetNull)

  year              Int
  quarter           Quarter
  fuelType          FuelType      @default(DI)
  status            ReportStatus  @default(DRAFT)

  totalMiles        Decimal       @default(0) @db.Decimal(12, 2)
  totalGallons      Decimal       @default(0) @db.Decimal(12, 2)
  averageMpg        Decimal       @default(0) @db.Decimal(10, 2)
  totalTaxDue       Decimal       @default(0) @db.Decimal(12, 2)

  filedAt           DateTime?
  notes             String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  lines             IftaReportLine[]
  trips             Trip[]
  fuelPurchases     FuelPurchase[]

  @@unique([userId, truckId, year, quarter, fuelType])
  @@index([userId, year, quarter])
}

model IftaReportLine {
  id                  String        @id @default(cuid())
  reportId            String
  report              IftaReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)

  jurisdictionId      String
  jurisdiction        Jurisdiction  @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  fuelType            FuelType      @default(DI)
  taxRate             Decimal       @db.Decimal(10, 4)

  taxableMiles        Decimal       @default(0) @db.Decimal(12, 2)
  taxableGallons      Decimal       @default(0) @db.Decimal(12, 2)
  paidGallons         Decimal       @default(0) @db.Decimal(12, 2)
  netTaxableGallons   Decimal       @default(0) @db.Decimal(12, 2)
  taxDue              Decimal       @default(0) @db.Decimal(12, 2)

  sortOrder           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([reportId, jurisdictionId, fuelType])
  @@index([reportId])
  @@index([jurisdictionId])
}

model Trip {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId        String?
  truck          Truck?         @relation(fields: [truckId], references: [id], onDelete: SetNull)

  reportId       String?
  report         IftaReport?    @relation(fields: [reportId], references: [id], onDelete: SetNull)

  tripDate       DateTime
  origin         String?
  destination    String?
  totalMiles     Decimal?       @db.Decimal(12, 2)
  notes          String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  mileages       TripMileage[]

  @@index([userId, tripDate])
  @@index([reportId])
}

model TripMileage {
  id               String        @id @default(cuid())
  tripId           String
  trip             Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  jurisdictionId   String
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  miles            Decimal       @default(0) @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([tripId, jurisdictionId])
  @@index([jurisdictionId])
}

model FuelPurchase {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId          String?
  truck            Truck?        @relation(fields: [truckId], references: [id], onDelete: SetNull)

  reportId         String?
  report           IftaReport?   @relation(fields: [reportId], references: [id], onDelete: SetNull)

  jurisdictionId   String
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  purchaseDate     DateTime
  fuelType         FuelType      @default(DI)
  gallons          Decimal       @db.Decimal(12, 2)
  pricePerGallon   Decimal?      @db.Decimal(10, 4)
  totalAmount      Decimal?      @db.Decimal(12, 2)
  vendor           String?
  receiptNumber    String?
  receiptUrl       String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId, purchaseDate])
  @@index([reportId])
  @@index([jurisdictionId])
}