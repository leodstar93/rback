{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": {
      "value": "production"
    }
  },
  "envPrefix": "",
  "regions": ["bom1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 3009,
      "maxDuration": 30
    }
  }
}
